{
  "name": "app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./*": {
      "types": "./src/*.d.ts",
      "default": [
        "./src/*",
        "./src/*.ts"
      ]
    }
  },
  "scripts": {
    "build": "marko-run build && node scripts/rebase-html.mjs",
    "deploy": "pnpm run build && gh-pages --nojekyll -d dist/public -u \"marko-js <noreply@markojs.com>\"",
    "dev": "marko-run",
    "format": "prettier . -w",
    "lint": "markdownlint \"docs/**/*.md\" && cspell \"**/*.{md,ts,marko}\"",
    "prepare": "husky",
    "preview": "marko-run preview"
  },
  "dependencies": {
    "@ebay/browserslist-config": "^2.15.0",
    "flexsearch": "^0.8.212"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@fontsource/ubuntu": "^5.2.8",
    "@fontsource/ubuntu-mono": "^5.2.8",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@jridgewell/source-map": "^0.3.11",
    "@marko/compiler": "^5.41.1",
    "@marko/run": "^0.11.4",
    "@marko/run-adapter-static": "^2.0.6",
    "@marko/type-check": "^3.1.2",
    "@resvg/resvg-js": "^2.6.2",
    "@rollup/browser": "^4.62.2",
    "@shikijs/langs": "^4.3.1",
    "@types/flexsearch": "^0.7.42",
    "@types/hast": "^3.0.5",
    "@types/node": "^26.1.1",
    "@types/semver": "^7.7.1",
    "assert": "./shim/assert",
    "autoprefixer": "^10.5.3",
    "codemirror": "^6.0.2",
    "cspell": "^10.0.1",
    "events": "^3.3.0",
    "gh-pages": "^6.3.0",
    "github-slugger": "^2.0.0",
    "glob": "^13.0.6",
    "hastscript": "^9.0.1",
    "husky": "^9.1.7",
    "lasso-package-root": "^1.0.1",
    "lightningcss-wasm": "^1.32.0",
    "lz-string": "^1.5.0",
    "markdownlint-cli": "^0.49.0",
    "marked": "^18.0.6",
    "marko": "^6.3.7",
    "path": "./shim/path",
    "path-browserify": "^1.0.1",
    "postcss": "^8.5.19",
    "postcss-import": "^16.1.1",
    "postcss-preset-env": "^11.3.2",
    "prettier": "^3.9.5",
    "prettier-plugin-marko": "^4.0.10",
    "prettier-plugin-packagejson": "^3.0.2",
    "pretty-format": "^30.4.1",
    "resolve-sync": "^1.2.2",
    "sass-embedded": "^1.100.0",
    "satori": "^0.28.0",
    "semver": "^7.8.5",
    "shiki": "^4.3.1",
    "terser": "^5.49.0",
    "util": "./shim/util",
    "vite": "^8.1.4",
    "writable-dom": "^1.0.6"
  },
  "packageManager": "pnpm@11.15.1"
}
