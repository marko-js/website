<!DOCTYPE html>
html lang="en"
  head
    meta charset="UTF-8"
    meta name="viewport" content="width=device-width, initial-scale=1.0"
    meta name="description" content="The Marko programming language"
    // PR preview deploys are served from a subdirectory and must not be indexed.
    if=(import.meta.env.BASE_URL !== "/")
      meta name="robots" content="noindex"
    title --
      ${
        typeof $global.meta.pageTitle === "string"
          ? `${$global.meta.pageTitle} | Marko`
          : "Marko"
      }
    meta property="og:title" content=($global.meta.pageTitle || "Marko")
    meta
      ,property="og:image"
      ,content=`https://markojs.com${import.meta.env.BASE_URL.replace(/\/$/, "")}${$global.meta.ogImage || "/og/default.png"}`
    meta property="og:image:width" content="1200"
    meta property="og:image:height" content="630"
    meta name="twitter:card" content="summary_large_image"
    link rel="icon" sizes="32x32" href="/fav.png"
    link rel="icon" type="image/svg+xml" href="/fav.svg"

    prefetch-links

  body spellcheck="false"
    div#root
      app-header
      main
        app-menu
        ${input.content}

    if=(!$global.meta.hideFooter)
      app-footer
